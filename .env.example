# Copy this file to .env and adjust values if needed.
# Defaults are compatible with local Docker Compose setup.

# Core Infrastructure

DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0

# Runtime

ENVIRONMENT=dev
JOB_DISPATCHER=celery

# Job Execution

JOB_EXECUTORS=["src.apps.reports.executors"]
JOB_MAX_RETRIES=3
JOB_DEFAULT_RETRY_DELAY=2
JOB_RETRY_BACKOFF_BASE=2
JOB_RETRY_BACKOFF_CAP_SECONDS=60
JOB_MAX_EXECUTION_SECONDS=300

# Outbox & Sweeper

OUTBOX_PUBLISH_INTERVAL_SECONDS=2.0
STUCK_JOB_SWEEP_INTERVAL_SECONDS=60.0

# Database Pool

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
